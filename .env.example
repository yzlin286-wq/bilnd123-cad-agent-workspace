# Server-side OpenAI-compatible model configuration. Never prefix these with NEXT_PUBLIC_.
CAD_AGENT_BASE_URL=https://api.example.com/v1
CAD_AGENT_API_KEY=replace-with-real-server-side-key
CAD_AGENT_PRIMARY_MODEL=primary-real-model
CAD_AGENT_DOWNGRADE_MODEL=secondary-real-model

# SaaS auth. Clerk is the preferred provider. Do not commit real keys.
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
SAAS_ADMIN_USER_IDS=
SAAS_ADMIN_EMAILS=

# One-time admin bootstrap. Set only in the shell that runs `npm run admin:bootstrap`.
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=replace-with-one-time-password
ADMIN_BOOTSTRAP_FIRST_NAME=CAD
ADMIN_BOOTSTRAP_LAST_NAME=Admin
ADMIN_BOOTSTRAP_RESET_PASSWORD=1
ADMIN_BOOTSTRAP_CREDENTIAL_PATH=/opt/bilnd123-cad-agent-workspace/admin-credential.txt
ADMIN_BOOTSTRAP_ENV_FILE=/opt/bilnd123-cad-agent-workspace/.env

# SaaS data layer. DATABASE_URL enables the Postgres adapter; without it the app uses logs/projects.json.
DATABASE_URL=
DATABASE_SSL=0
POSTGRES_USER=cad_agent
POSTGRES_PASSWORD=replace-with-strong-postgres-password
POSTGRES_DB=cad_agent
SAAS_DEV_AUTH_BYPASS=0
SAAS_DEV_USER_ID=local-dev-user
SAAS_DEV_ORG_ID=local-dev-org
SAAS_DEV_ADMIN=0

# Real CAD runner. This must point to a Python environment with requirements.txt installed.
CAD_RUNNER_COMMAND=python scripts/run_build123d.py
CAD_RUNNER_TIMEOUT_MS=60000
CAD_MAX_CONCURRENT_RUNS=1
APT_MIRROR=http://deb.debian.org/debian
APT_SECURITY_MIRROR=http://deb.debian.org/debian-security
PIP_INDEX_URL=https://pypi.org/simple

# Staging access gate. Required on staging servers; optional for local development.
STAGING_BASIC_AUTH_USER=replace-with-staging-user
STAGING_BASIC_AUTH_PASSWORD=replace-with-strong-staging-password

# Optional HTTPS reverse proxy settings for docker-compose.staging.https.yml.
STAGING_DOMAIN=cad-staging.example.com
LETSENCRYPT_EMAIL=ops@example.com
STAGING_ACCESS_MODE=unknown

# Staging safety limits.
MAX_PROMPT_CHARS=2000
CAD_OUTPUT_RETENTION_HOURS=72
CAD_OUTPUT_MAX_BYTES=1073741824
